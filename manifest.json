{
  "manifest_version": 3,
  "name": "Comment Generator",
  "version": "2.2.7",
  "description": "Generate comments with custom tone using Claude AI",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Generate Comment"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  }
}
